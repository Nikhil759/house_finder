# ── Database ──────────────────────────────────────────────────────────────────
# Full Postgres connection string (provided by Railway in production).
# Leave unset to use a local SQLite file (alerts.db) in development.
DATABASE_URL=

# ── Telegram MTProto API ───────────────────────────────────────────────────────
# Obtain from https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Name of the local .session file (no extension). Defaults to "housing_finder".
TELEGRAM_SESSION_NAME=housing_finder

# ── Email alerts (Resend) ──────────────────────────────────────────────────────
# Obtain from https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender address configured in your Resend domain settings.
# Defaults to the Resend sandbox address if unset.
RESEND_FROM_EMAIL=

# ── Flask server ───────────────────────────────────────────────────────────────
# Port the development server listens on. Defaults to 5001.
PORT=5001
# Set to "true" to enable Flask debug mode. Never set to "true" in production.
FLASK_DEBUG=false
